+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Microbenchmark for the aiter Triton ``gemm_a16w16`` path that vLLM uses
+for GPT-OSS decode-time attention GEMMs on AMD MI355X (gfx950).
+
+The two hot shapes covered here are:
+
+* ``M=64, N=5120, K=2880`` — QKV-family projection.
+* ``M=64, N=2880, K=4096`` — output-projection-family GEMM.
+
+These match the dispatch table in
+``vllm/model_executor/layers/utils.py::use_aiter_triton_gemm`` and are the
+shapes that benefit from the gfx950-specialized aiter kernel. The script
+prints per-shape latency and TFLOPS for ``aiter.ops.triton.gemm_a16w16``
+versus ``torch.nn.functional.linear`` (hipBLASLt) so reviewers can
+reproduce upstream-kernel claims on their own MI355X machine.
+
+Usage::
+
+    python benchmarks/kernels/benchmark_aiter_gemm_a16w16_m64.py
+    python benchmarks/kernels/benchmark_aiter_gemm_a16w16_m64.py --dtype float16
+    python benchmarks/kernels/benchmark_aiter_gemm_a16w16_m64.py --warmup 50 --iters 500
+"""
+
+from __future__ import annotations
+
+import argparse
+
+import torch
+
+try:
+    from aiter.ops.triton.gemm_a16w16 import gemm_a16w16 as aiter_gemm_a16w16
+except ImportError:  # pragma: no cover - aiter is optional
+    aiter_gemm_a16w16 = None
+
+
+SHAPES: list[tuple[str, int, int, int]] = [
+    ("qkv", 64, 5120, 2880),
+    ("o_proj", 64, 2880, 4096),
+]
+
+
+def _bench(fn, warmup: int, iters: int) -> float:
+    for _ in range(warmup):
+        fn()
+    torch.cuda.synchronize()
+    start = torch.cuda.Event(enable_timing=True)
+    end = torch.cuda.Event(enable_timing=True)
+    start.record()
+    for _ in range(iters):
+        fn()
+    end.record()
+    torch.cuda.synchronize()
+    return start.elapsed_time(end) / iters
+
+
+def _row(label: str, m: int, n: int, k: int, ms: float) -> str:
+    flops = 2.0 * m * n * k
+    tflops = flops / (ms * 1e-3) / 1e12
+    return f"  {label:<18s} {ms:8.4f} ms   {tflops:7.2f} TFLOPS"
+
+
+def run(args: argparse.Namespace) -> int:
+    if not torch.cuda.is_available():
+        print("CUDA / ROCm device not available; skipping benchmark.")
+        return 0
+
+    dtype = {"float16": torch.float16, "bfloat16": torch.bfloat16}[args.dtype]
+    device = torch.device("cuda")
+
+    for label, m, n, k in SHAPES:
+        a = torch.randn((n, k), dtype=dtype, device=device)
+        b = torch.randn((m, k), dtype=dtype, device=device)
+        ref = lambda a=a, b=b: torch.nn.functional.linear(a, b)
+        print(f"shape={label} M={m} N={n} K={k} dtype={args.dtype}")
+        ref_ms = _bench(ref, args.warmup, args.iters)
+        print(_row("torch.linear", m, n, k, ref_ms))
+
+        if aiter_gemm_a16w16 is None:
+            print("  aiter.gemm_a16w16  not installed; skipping")
+            continue
+
+        gemm = lambda a=a, b=b: aiter_gemm_a16w16(a, b, None)
+        # Warmup with a single call to surface compile errors early.
+        try:
+            gemm()
+        except Exception as exc:  # pragma: no cover
+            print(f"  aiter.gemm_a16w16  unavailable on this device: {exc}")
+            continue
+        aiter_ms = _bench(gemm, args.warmup, args.iters)
+        print(_row("aiter.gemm_a16w16", m, n, k, aiter_ms))
+        speedup = ref_ms / aiter_ms if aiter_ms > 0 else float("nan")
+        print(f"  speedup vs torch    {speedup:7.2f}x")
+
+    return 0
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument(
+        "--dtype",
+        default="bfloat16",
+        choices=("bfloat16", "float16"),
+        help="Input/output dtype.",
+    )
+    parser.add_argument("--warmup", type=int, default=25)
+    parser.add_argument("--iters", type=int, default=200)
+    return parser.parse_args()
+
+
+if __name__ == "__main__":
+    raise SystemExit(run(parse_args()))
